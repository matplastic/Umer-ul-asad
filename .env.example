VITE_FIREBASE_API_KEY=AIzaSy...your real key here...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:...your app id...

# --- Postgres (primary database, via Drizzle) ---
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Sign-in / user accounts (see server.ts "SIGN-IN & USER ACCOUNTS") ---
# REQUIRED for username/password login to work: a Firebase service account,
# so the server can sign custom tokens. In the Firebase Console go to
# Project Settings -> Service Accounts -> Generate new private key, then
# either:
#   a) paste the entire downloaded JSON file as one line here:
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...", ...}
#   b) OR, for local dev only, save the JSON file somewhere and instead set:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json
# Without one of these, /api/auth/login will fail — the server will log a
# warning on startup reminding you.

# --- Store / BOM material request approval emails ---
# Sign up free at https://resend.com, verify a sending domain, create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
STORE_EMAIL_FROM="Your Company Store <store@yourcompany.com>"
# Comma-separate multiple managers, e.g. "manager1@yourcompany.com,manager2@yourcompany.com"
STORE_MANAGER_EMAIL=manager1@yourcompany.com,manager2@yourcompany.com
# Public URL of your deployed app (used to build the Approve/Reject links in the email)
APP_BASE_URL=https://your-deployed-app-url.com
